rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Products - publicly readable, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Users - users can read/write their own data, admins can read/write all
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }
    
    // Orders - authenticated users can create and read their own orders
    // Admins can read and update all orders
    match /orders/{orderId} {
      allow create: if isAuthenticated() || true; // Allow guest checkout too
      allow read: if isAuthenticated() && 
        resource.data.customerInfo.email == request.auth.token.email ||
        isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Categories - publicly readable, only admins can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
